# Copy to .env.local and fill in values used by the classroom demo.

# REQUIRED: Single LLM gateway key.
OPENROUTER_API_KEY=

# OPTIONAL: OpenRouter model slug. Defaults to anthropic/claude-sonnet-4.5 — the
# best cost/quality pick for the live classroom demo (same price as Sonnet 4 but
# newer and stronger at agentic tool use).
#
# Other vetted picks:
#   anthropic/claude-haiku-4.5   ~3x cheaper, ideal for rehearsals
#   openai/gpt-5                 ~50% cheaper, cross-vendor sanity check
#   openai/gpt-5-mini            ~12x cheaper, fine for dev iteration
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# OPTIONAL: OpenAlex free-tier API key. The free tier gives $1/day of usage,
# which on our access pattern means effectively unlimited classroom use:
#   - Single-DOI GETs are unlimited and free
#   - List+filter calls (our default search path): 10,000/day
#   - Search calls (we don't use this path): 1,000/day
#   - Content/PDF downloads (we don't use these): 100/day
# Without a key, OpenAlex falls back to the polite pool with a `mailto`.
OPENALEX_API_KEY=

# OPTIONAL: only needed when the user enables "Allow supplementary web search".
TAVILY_API_KEY=

# OPTIONAL: set this to require clients to send an x-demo-token header. Useful
# when the demo is hosted publicly and you want to gate access.
DEMO_ACCESS_TOKEN=
